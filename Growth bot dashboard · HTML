<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Growth Hunter — Geleceğin NVIDIA'sını Bul</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@300;400;500;700&display=swap');

  :root {
    --bg: #080c14;
    --surface: #0d1421;
    --border: #1a2540;
    --accent: #00d4ff;
    --green: #00ff9d;
    --yellow: #ffcc00;
    --red: #ff4466;
    --text: #e0e8f0;
    --muted: #4a6080;
    --card: #111827;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* Grid arka plan */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 40px 40px;
    opacity: 0.3;
    pointer-events: none;
    z-index: 0;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 24px;
    position: relative;
    z-index: 1;
  }

  /* HEADER */
  header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 24px 0 32px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 32px;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .logo-icon {
    width: 44px;
    height: 44px;
    background: linear-gradient(135deg, #00d4ff, #00ff9d);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
  }

  .logo h1 {
    font-family: 'Space Mono', monospace;
    font-size: 18px;
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.5px;
  }

  .logo p {
    font-size: 12px;
    color: var(--muted);
    font-weight: 300;
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .status-pill {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 20px;
    font-size: 12px;
    font-family: 'Space Mono', monospace;
    color: var(--muted);
  }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--green);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .btn-scan {
    padding: 8px 20px;
    background: linear-gradient(135deg, var(--accent), var(--green));
    color: #000;
    border: none;
    border-radius: 8px;
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    font-weight: 700;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.1s;
  }

  .btn-scan:hover { opacity: 0.85; transform: translateY(-1px); }
  .btn-scan:active { transform: translateY(0); }
  .btn-scan:disabled { opacity: 0.4; cursor: not-allowed; }

  /* STATS BAR */
  .stats-bar {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    margin-bottom: 28px;
  }

  .stat-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 16px 20px;
    position: relative;
    overflow: hidden;
  }

  .stat-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--accent-color, var(--accent));
  }

  .stat-card.green { --accent-color: var(--green); }
  .stat-card.yellow { --accent-color: var(--yellow); }
  .stat-card.blue { --accent-color: var(--accent); }

  .stat-label {
    font-size: 11px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 8px;
    font-family: 'Space Mono', monospace;
  }

  .stat-value {
    font-size: 28px;
    font-weight: 700;
    color: #fff;
    font-family: 'Space Mono', monospace;
  }

  .stat-sub {
    font-size: 11px;
    color: var(--muted);
    margin-top: 4px;
  }

  /* FILTERS */
  .filters {
    display: flex;
    gap: 8px;
    margin-bottom: 24px;
    flex-wrap: wrap;
  }

  .filter-btn {
    padding: 6px 16px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--muted);
    font-size: 13px;
    cursor: pointer;
    transition: all 0.2s;
    font-family: 'DM Sans', sans-serif;
  }

  .filter-btn:hover { border-color: var(--accent); color: var(--accent); }
  .filter-btn.active {
    background: var(--accent);
    border-color: var(--accent);
    color: #000;
    font-weight: 700;
  }

  /* SIGNAL CARDS */
  .signals-grid {
    display: grid;
    gap: 12px;
  }

  .signal-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 20px 24px;
    cursor: pointer;
    transition: border-color 0.2s, transform 0.1s;
    position: relative;
    overflow: hidden;
  }

  .signal-card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--card-accent, var(--muted));
  }

  .signal-card.strong { --card-accent: var(--green); }
  .signal-card.candidate { --card-accent: var(--yellow); }
  .signal-card.watch { --card-accent: var(--accent); }

  .signal-card:hover {
    border-color: var(--card-accent, var(--muted));
    transform: translateX(2px);
  }

  .signal-card.expanded { border-color: var(--card-accent, var(--muted)); }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .card-left {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .symbol-box {
    font-family: 'Space Mono', monospace;
    font-weight: 700;
    font-size: 18px;
    color: #fff;
    min-width: 60px;
  }

  .decision-badge {
    padding: 4px 10px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 700;
    font-family: 'Space Mono', monospace;
    letter-spacing: 0.5px;
  }

  .decision-badge.strong { background: rgba(0,255,157,0.15); color: var(--green); border: 1px solid rgba(0,255,157,0.3); }
  .decision-badge.candidate { background: rgba(255,204,0,0.15); color: var(--yellow); border: 1px solid rgba(255,204,0,0.3); }
  .decision-badge.watch { background: rgba(0,212,255,0.15); color: var(--accent); border: 1px solid rgba(0,212,255,0.3); }

  .card-right {
    display: flex;
    align-items: center;
    gap: 20px;
    text-align: right;
  }

  .price-display {
    font-family: 'Space Mono', monospace;
    font-size: 20px;
    font-weight: 700;
    color: #fff;
  }

  .score-display {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .score-num {
    font-family: 'Space Mono', monospace;
    font-size: 16px;
    font-weight: 700;
    color: var(--card-accent, var(--accent));
  }

  .score-label {
    font-size: 10px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .mini-stats {
    display: flex;
    gap: 20px;
    margin-top: 12px;
    padding-top: 12px;
    border-top: 1px solid var(--border);
  }

  .mini-stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .mini-stat-label {
    font-size: 10px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-family: 'Space Mono', monospace;
  }

  .mini-stat-value {
    font-size: 13px;
    font-weight: 500;
    color: var(--text);
    font-family: 'Space Mono', monospace;
  }

  /* EXPANDED DETAILS */
  .details {
    display: none;
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid var(--border);
  }

  .signal-card.expanded .details { display: block; }

  .details-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .details-section h4 {
    font-size: 11px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 1px;
    font-family: 'Space Mono', monospace;
    margin-bottom: 10px;
  }

  .detail-item {
    font-size: 12px;
    color: var(--text);
    padding: 4px 0;
    line-height: 1.6;
  }

  /* SCORE BAR */
  .score-bars {
    display: flex;
    gap: 8px;
    margin-top: 12px;
    align-items: center;
  }

  .score-bar-label {
    font-size: 11px;
    color: var(--muted);
    font-family: 'Space Mono', monospace;
    width: 50px;
    text-align: right;
  }

  .score-bar-track {
    flex: 1;
    height: 6px;
    background: var(--border);
    border-radius: 3px;
    overflow: hidden;
  }

  .score-bar-fill {
    height: 100%;
    border-radius: 3px;
    transition: width 0.5s ease;
  }

  .score-bar-fill.tech { background: var(--accent); }
  .score-bar-fill.fund { background: var(--green); }

  .score-bar-num {
    font-size: 11px;
    color: var(--text);
    font-family: 'Space Mono', monospace;
    width: 30px;
  }

  /* EMPTY STATE */
  .empty-state {
    text-align: center;
    padding: 80px 20px;
    color: var(--muted);
  }

  .empty-state .icon { font-size: 48px; margin-bottom: 16px; }
  .empty-state h3 { font-size: 18px; color: var(--text); margin-bottom: 8px; }
  .empty-state p { font-size: 14px; }

  /* SCANNING ANIMATION */
  .scanning-bar {
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
    background-size: 200% 100%;
    animation: scan 1.5s linear infinite;
    border-radius: 1px;
    margin-bottom: 24px;
    display: none;
  }

  .scanning-bar.active { display: block; }

  @keyframes scan {
    0% { background-position: -100% 0; }
    100% { background-position: 200% 0; }
  }

  /* FOOTER */
  .footer {
    margin-top: 48px;
    padding-top: 20px;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 11px;
    color: var(--muted);
    font-family: 'Space Mono', monospace;
  }

  #lastScanTime { color: var(--accent); }

  @media (max-width: 768px) {
    .stats-bar { grid-template-columns: repeat(2, 1fr); }
    .details-grid { grid-template-columns: 1fr; }
    .mini-stats { flex-wrap: wrap; gap: 12px; }
    header { flex-direction: column; gap: 16px; align-items: flex-start; }
  }
</style>
</head>
<body>

<div class="container">
  <header>
    <div class="logo">
      <div class="logo-icon">🚀</div>
      <div>
        <h1>GROWTH HUNTER</h1>
        <p>Geleceğin NVIDIA'sını bul — $20 altı büyüme hisseleri</p>
      </div>
    </div>
    <div class="header-right">
      <div class="status-pill">
        <div class="status-dot" id="statusDot"></div>
        <span id="statusText">Hazır</span>
      </div>
      <button class="btn-scan" id="scanBtn" onclick="startScan()">⚡ Tara</button>
    </div>
  </header>

  <div class="scanning-bar" id="scanningBar"></div>

  <div class="stats-bar">
    <div class="stat-card green">
      <div class="stat-label">🚀 Güçlü Büyüme</div>
      <div class="stat-value" id="countStrong">—</div>
      <div class="stat-sub">Skor ≥ 7/12</div>
    </div>
    <div class="stat-card yellow">
      <div class="stat-label">⭐ Büyüme Adayı</div>
      <div class="stat-value" id="countCandidate">—</div>
      <div class="stat-sub">Skor 5-6/12</div>
    </div>
    <div class="stat-card blue">
      <div class="stat-label">👀 İzle</div>
      <div class="stat-value" id="countWatch">—</div>
      <div class="stat-sub">Skor 3-4/12</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">⏱ Son Tarama</div>
      <div class="stat-value" style="font-size:14px;margin-top:4px" id="lastScanTime">—</div>
      <div class="stat-sub">Her gün 23:30 TR</div>
    </div>
  </div>

  <div class="filters">
    <button class="filter-btn active" onclick="setFilter('all', this)">Tümü</button>
    <button class="filter-btn" onclick="setFilter('strong', this)">🚀 Güçlü Büyüme</button>
    <button class="filter-btn" onclick="setFilter('candidate', this)">⭐ Büyüme Adayı</button>
    <button class="filter-btn" onclick="setFilter('watch', this)">👀 İzle</button>
  </div>

  <div class="signals-grid" id="signalsGrid">
    <div class="empty-state">
      <div class="icon">🔍</div>
      <h3>Henüz tarama yapılmadı</h3>
      <p>⚡ Tara butonuna bas, bot $1-$20 arası büyüme adaylarını analiz etsin</p>
    </div>
  </div>

  <div class="footer">
    <span>Growth Hunter Bot v1.0 — FMP + Yahoo Finance</span>
    <span>Sadece bilgi amaçlıdır, yatırım tavsiyesi değildir</span>
  </div>
</div>

<script>
  // ── CONFIG ──────────────────────────────────────────
  // Render'daki yeni bot URL'ini buraya yaz
  const BOT_URL = 'https://growth-hunter-bot.onrender.com';

  let allSignals = [];
  let currentFilter = 'all';
  let polling = null;

  // ── FILTER ──────────────────────────────────────────
  function setFilter(f, btn) {
    currentFilter = f;
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    renderSignals();
  }

  // ── SCAN ────────────────────────────────────────────
  async function startScan() {
    const btn = document.getElementById('scanBtn');
    btn.disabled = true;
    btn.textContent = '⏳ Taranıyor...';
    document.getElementById('scanningBar').classList.add('active');
    document.getElementById('statusText').textContent = 'Taranıyor...';

    try {
      await fetch(`${BOT_URL}/scan`);
      pollResults();
    } catch (e) {
      alert('Bot\'a bağlanılamadı. URL\'yi kontrol et: ' + BOT_URL);
      resetScanBtn();
    }
  }

  function pollResults() {
    let tries = 0;
    polling = setInterval(async () => {
      tries++;
      await loadSignals();
      if (tries > 60) { // 10 dakika sonra durdur
        clearInterval(polling);
        resetScanBtn();
      }
    }, 10000); // 10 saniyede bir kontrol
  }

  function resetScanBtn() {
    const btn = document.getElementById('scanBtn');
    btn.disabled = false;
    btn.textContent = '⚡ Tara';
    document.getElementById('scanningBar').classList.remove('active');
    document.getElementById('statusText').textContent = 'Hazır';
  }

  // ── LOAD DATA ───────────────────────────────────────
  async function loadSignals() {
    try {
      const res = await fetch(`${BOT_URL}/signals`);
      const data = await res.json();

      allSignals = data.signals || [];

      // Stats güncelle
      document.getElementById('countStrong').textContent =
        allSignals.filter(s => s.decision === 'GÜÇLÜ BÜYÜME').length;
      document.getElementById('countCandidate').textContent =
        allSignals.filter(s => s.decision === 'BÜYÜME ADAYI').length;
      document.getElementById('countWatch').textContent =
        allSignals.filter(s => s.decision === 'İZLE').length;

      if (data.lastScan) {
        const d = new Date(data.lastScan);
        document.getElementById('lastScanTime').textContent =
          d.toLocaleString('tr-TR', { day:'2-digit', month:'2-digit', hour:'2-digit', minute:'2-digit' });
        resetScanBtn();
        if (polling) clearInterval(polling);
      }

      renderSignals();
    } catch (e) {
      console.error('Sinyal yüklenemedi:', e);
    }
  }

  // ── RENDER ──────────────────────────────────────────
  function renderSignals() {
    const grid = document.getElementById('signalsGrid');

    let list = allSignals;
    if (currentFilter === 'strong') list = list.filter(s => s.decision === 'GÜÇLÜ BÜYÜME');
    else if (currentFilter === 'candidate') list = list.filter(s => s.decision === 'BÜYÜME ADAYI');
    else if (currentFilter === 'watch') list = list.filter(s => s.decision === 'İZLE');

    if (list.length === 0) {
      grid.innerHTML = `
        <div class="empty-state">
          <div class="icon">${allSignals.length > 0 ? '🔍' : '🚀'}</div>
          <h3>${allSignals.length > 0 ? 'Bu filtrede sonuç yok' : 'Henüz tarama yapılmadı'}</h3>
          <p>${allSignals.length > 0 ? 'Farklı bir filtre dene' : '⚡ Tara butonuna bas'}</p>
        </div>`;
      return;
    }

    grid.innerHTML = list.map((s, i) => {
      const cls = s.decision === 'GÜÇLÜ BÜYÜME' ? 'strong' : s.decision === 'BÜYÜME ADAYI' ? 'candidate' : 'watch';
      const techPct = (s.techScore / 6) * 100;
      const fundPct = (s.fundScore / 6) * 100;

      return `
        <div class="signal-card ${cls}" onclick="toggleCard(this)">
          <div class="card-header">
            <div class="card-left">
              <div class="symbol-box">${s.symbol}</div>
              <div class="decision-badge ${cls}">${s.badge} ${s.decision}</div>
            </div>
            <div class="card-right">
              <div class="price-display">$${s.price?.toFixed(2)}</div>
              <div class="score-display">
                <div class="score-num">${s.totalScore}/12</div>
                <div class="score-label">SKOR</div>
              </div>
            </div>
          </div>

          <div class="mini-stats">
            <div class="mini-stat">
              <div class="mini-stat-label">SMA20</div>
              <div class="mini-stat-value">$${s.sma20}</div>
            </div>
            <div class="mini-stat">
              <div class="mini-stat-label">SMA50</div>
              <div class="mini-stat-value">$${s.sma50}</div>
            </div>
            <div class="mini-stat">
              <div class="mini-stat-label">3ay perf</div>
              <div class="mini-stat-value" style="color:${s.perf3m >= 0 ? 'var(--green)' : 'var(--red)'}">
                ${s.perf3m >= 0 ? '+' : ''}${s.perf3m}%
              </div>
            </div>
            <div class="mini-stat">
              <div class="mini-stat-label">Hacim trendi</div>
              <div class="mini-stat-value" style="color:${s.volTrend >= 1.2 ? 'var(--green)' : 'var(--muted)'}">
                ${s.volTrend}x
              </div>
            </div>
            <div class="mini-stat">
              <div class="mini-stat-label">52w düşük</div>
              <div class="mini-stat-value">+${s.fromLow}%</div>
            </div>
          </div>

          <div class="details">
            <div class="score-bars" style="margin-bottom:16px">
              <div class="score-bar-label">TEKNİK</div>
              <div class="score-bar-track"><div class="score-bar-fill tech" style="width:${techPct}%"></div></div>
              <div class="score-bar-num">${s.techScore}/6</div>
            </div>
            <div class="score-bars" style="margin-bottom:16px">
              <div class="score-bar-label">FUND.</div>
              <div class="score-bar-track"><div class="score-bar-fill fund" style="width:${fundPct}%"></div></div>
              <div class="score-bar-num">${s.fundScore}/6</div>
            </div>

            <div class="details-grid">
              <div class="details-section">
                <h4>📊 Teknik Analiz</h4>
                ${(s.techDetails || []).map(d => `<div class="detail-item">${d}</div>`).join('')}
              </div>
              <div class="details-section">
                <h4>📈 Fundamental Analiz</h4>
                ${(s.fundDetails || []).map(d => `<div class="detail-item">${d}</div>`).join('')}
              </div>
            </div>
          </div>
        </div>`;
    }).join('');
  }

  function toggleCard(el) {
    el.classList.toggle('expanded');
  }

  // ── İLK YÜKLEME ─────────────────────────────────────
  loadSignals();
  // Her 2 dakikada otomatik yenile
  setInterval(loadSignals, 120000);
</script>
</body>
</html>
